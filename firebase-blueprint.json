{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "viewer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Signal": {
      "title": "Signal",
      "description": "A trading signal generated by the AI model",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "symbol": { "type": "string" },
        "type": { "type": "string", "enum": ["BUY", "SELL"] },
        "entry": { "type": "number" },
        "tp": { "type": "number" },
        "sl": { "type": "number" },
        "confidence": { "type": "number" },
        "status": { "type": "string", "enum": ["PENDING", "ACTIVE", "CLOSED"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["symbol", "type", "entry", "timestamp"]
    },
    "SystemLog": {
      "title": "SystemLog",
      "description": "Maintenance and execution logs",
      "type": "object",
      "properties": {
        "level": { "type": "string", "enum": ["INFO", "WARN", "ERROR"] },
        "message": { "type": "string" },
        "source": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["level", "message", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/signals/{signalId}": {
      "schema": "Signal",
      "description": "Trading signals"
    },
    "/logs/{logId}": {
      "schema": "SystemLog",
      "description": "System execution logs"
    }
  }
}
